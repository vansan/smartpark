rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Parking Locations — any authenticated user can read
    match /parking_locations/{locationId} {
      allow read: if request.auth != null;
      allow write: if false; // Only seeded via service account
    }

    // Parking Slots — any authenticated user can read; only write via transaction
    match /parking_slots/{slotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bookings — user can read own bookings; create if authenticated
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
                    (resource.data.userId == request.auth.uid || true); // Guards can read
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null; // Guard updates
    }
  }
}
